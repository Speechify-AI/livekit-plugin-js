{
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": ".",
    "target": "es2022",
    "types": ["node"],
    "module": "node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "declarationDir": "./dist",
    "outDir": "./dist"
  },
  "include": ["./src"]
}
